<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Penyedia Kerja (Nama UMKM)"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etCompanyName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Contoh: Warung Makmur Sejahtera"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Posisi Pekerjaan"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etJobTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Contoh: Supervisor Restoran"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deskripsi Pekerjaan"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etJobDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Tulis deskripsi tugas pekerjaan..."
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Persyaratan Dokumen"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etRequiredDocuments"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Contoh: CV, Fotokopi KTP, Ijazah"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batas Maksimal Pelamar"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etMaxApplicants"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Contoh: 150"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gaji / Bulan"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etSalary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Contoh: Rp 4,500,000 - Rp 5,500,000"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSaveJob"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Post Lowongan"
            android:textColor="@color/white"
            android:backgroundTint="#5B93D3"
            android:textStyle="bold"
            app:cornerRadius="8dp"/>
    </LinearLayout>
</ScrollView>