<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Profil Pelamar"
            android:textColor="#2D3748"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- SEKSI 1: PROFIL PUBLIK SEEKER -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivDetailSeekerPhoto"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvDetailSeekerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memuat nama..."
                    android:textColor="#2D3748"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvDetailSeekerEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="#718096"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDetailSeekerPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Telepon: -"
                    android:textColor="#718096"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDetailSeekerAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alamat: -"
                    android:textColor="#718096"
                    android:textSize="14sp"
                    android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SEKSI 2: PESAN TAMBAHAN & DOKUMEN LAMPIRAN -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pesan Tambahan Pelamar" android:textStyle="bold" android:textColor="#4A5568" android:layout_marginBottom="6dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvDetailSeekerNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="-"
                android:textColor="#4A5568"
                android:textSize="14sp"/>
        </androidx.cardview.widget.CardView>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dokumen Lampiran" android:textStyle="bold" android:textColor="#4A5568" android:layout_marginBottom="6dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <TextView android:id="@+id/tvDetailDocNameHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Memuat Berkas..." android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <ImageView
                    android:id="@+id/ivDetailDocumentImage"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:scaleType="fitCenter"
                    android:background="#E2E8F0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- STATUS SEKARANG -->
        <TextView
            android:id="@+id/tvDetailCurrentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status Saat Ini: Diproses"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#2B6CB0"
            android:layout_marginBottom="20dp"/>

        <!-- SEKSI 3: BUTTON PROSES AKSI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnProcessReject"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Tolak"
                android:textColor="@color/white"
                android:backgroundTint="#E53E3E"
                android:textStyle="bold"
                app:cornerRadius="10dp"/>
            <Button
                android:id="@+id/btnProcessInterview"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Wawancara"
                android:textColor="@color/white"
                android:backgroundTint="#38A169"
                android:textStyle="bold"
                app:cornerRadius="10dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>