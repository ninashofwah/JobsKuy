<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- BARIS PERBAIKAN: Mengganti wrap_width menjadi wrap_content -->
        <TextView
            android:id="@+id/tvItemApplicantEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading Email..."
            android:textColor="#2D3748"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemApplicantStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@android:drawable/toast_frame"
            android:backgroundTint="#FFF5F5"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Status: Diproses"
            android:textColor="#E53E3E"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>