<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvDashboardSeeker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JobsKuy"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_centerVertical="true"/>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfileSeeker"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    android:layout_alignParentEnd="true"
                    android:scaleType="centerCrop"/>
            </RelativeLayout>

            <EditText
                android:id="@+id/etSearchJob"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@android:drawable/editbox_background"
                android:hint="🔍 Cari posisi atau perusahaan..."
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lowongan Tersedia :"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D3748"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAvailableJobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_job_recruiter"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>