<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Posisi Pekerjaan"
            android:textColor="#2D3748"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDetailCompany"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Perusahaan UMKM"
            android:textColor="#718096"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginVertical="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰 Estimasi Gaji" android:textStyle="bold" android:textColor="#2D3748"/>
        <TextView android:id="@+id/tvDetailSalary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp -" android:textColor="#4A5568" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📝 Deskripsi Tugas" android:textStyle="bold" android:textColor="#2D3748"/>
        <TextView android:id="@+id/tvDetailDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Memuat deskripsi..." android:textColor="#4A5568" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📁 Dokumen Wajib" android:textStyle="bold" android:textColor="#2D3748"/>
        <TextView android:id="@+id/tvDetailDocs" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Memuat persyaratan..." android:textColor="#4A5568" android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnApplyJob"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Kirim Lamaran Sekarang"
            android:textColor="@color/white"
            android:backgroundTint="#2B6CB0"
            android:textStyle="bold"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</ScrollView>