<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan Profil Akun Seeker"
            android:textColor="#2D3748"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Foto Profil -->
        <ImageView
            android:id="@+id/ivProfilePicSeeker"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:scaleType="centerCrop"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- Card Data Diri -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:id="@+id/tvSeekerProfileName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="#2D3748" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvSeekerProfileEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="#718096" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvSeekerProfilePhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Telepon: -" android:textColor="#718096" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvSeekerProfileAddress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alamat: -" android:textColor="#718096" android:textSize="14sp" android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvSeekerProfileRole" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@android:drawable/toast_frame" android:backgroundTint="#F7FAFC" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:text="Kategori Akun: -" android:textColor="#4A5568" android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SEKSI DINAMIS: GUDANG DOKUMEN PRIBADI -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📁 Gudang Dokumen Pribadi Saya"
            android:textStyle="bold"
            android:textColor="#2B6CB0"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Form Input Teks untuk Tambah Nama Dokumen Kustom Baru -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/etNewProfileDocName"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:hint="Ketik nama dokumen (Misal: Sertifikat)"
                        android:textSize="14sp"
                        android:background="@android:drawable/editbox_background"
                        android:paddingHorizontal="12dp"/>
                    <Button
                        android:id="@+id/btnAddNewProfileDocRow"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:layout_marginStart="8dp"
                        android:text="+ Tambah"
                        android:textSize="12sp"
                        android:backgroundTint="#2B6CB0"
                        android:textColor="@color/white"
                        app:cornerRadius="8dp"/>
                </LinearLayout>

                <!-- KONTANER TEMPAT BARIS-BARIS DOKUMEN AKAN MUNCUL SECARA OTOMATIS -->
                <LinearLayout
                    android:id="@+id/containerProfileDocuments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol Aksi Utama -->
        <Button
            android:id="@+id/btnEditProfileSeeker"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="✏️ Edit Data Profil"
            android:textColor="@color/white"
            android:backgroundTint="#4A77B4"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnLogoutSeeker"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Keluar / Logout Akun"
            android:textColor="@color/white"
            android:backgroundTint="#E53E3E"
            android:textStyle="bold"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</ScrollView>