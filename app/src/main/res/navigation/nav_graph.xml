<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/roleSelectionFragment">

    <fragment
        android:id="@+id/roleSelectionFragment"
        android:name="com.proweb.jobskuy.ui.auth.RoleSelectionFragment"
        android:label="Pilih Peran"
        tools:layout="@layout/fragment_role_selection">
        <action
            android:id="@+id/action_role_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.proweb.jobskuy.ui.auth.LoginFragment"
        android:label="Masuk Akun"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_registerEmail"
            app:destination="@id/registerEmailFragment" />
        <action
            android:id="@+id/action_login_to_homeSeeker"
            app:destination="@id/homeSeekerFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_homeRecruiter"
            app:destination="@id/homeRecruiterFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerEmailFragment"
        android:name="com.proweb.jobskuy.ui.auth.RegisterEmailFragment"
        android:label="Verifikasi OTP"
        tools:layout="@layout/fragment_register_email">
        <action
            android:id="@+id/action_registerEmail_to_registerProfile"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.proweb.jobskuy.ui.auth.RegisterFragment"
        android:label="Isi Profil Data Diri"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_homeSeeker"
            app:destination="@id/homeSeekerFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_homeRecruiter"
            app:destination="@id/homeRecruiterFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeRecruiterFragment"
        android:name="com.proweb.jobskuy.ui.home.HomeRecruiterFragment"
        android:label="Home Recruiter"
        tools:layout="@layout/fragment_home_recruiter">
        <action
            android:id="@+id/action_homeRecruiter_to_createJob"
            app:destination="@id/createJobFragment" />
        <action
            android:id="@+id/action_homeRecruiter_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/myJobsFragment"
        android:name="com.proweb.jobskuy.ui.home.MyJobsFragment"
        android:label="Lowongan Saya"
        tools:layout="@layout/fragment_my_jobs" />

    <fragment
        android:id="@+id/applicantListFragment"
        android:name="com.proweb.jobskuy.ui.home.ApplicantListFragment"
        android:label="Daftar Pelamar"
        tools:layout="@layout/fragment_applicant_list" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.proweb.jobskuy.ui.profile.ProfileFragment"
        android:label="Profil Recruiter"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileRecruiter_to_roleSelection"
            app:destination="@id/roleSelectionFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/createJobFragment"
        android:name="com.proweb.jobskuy.ui.home.CreateJobFragment"
        android:label="Buat Lowongan Baru"
        tools:layout="@layout/fragment_create_job">
        <action
            android:id="@+id/action_createJob_to_homeRecruiter"
            app:destination="@id/homeRecruiterFragment"
            app:popUpTo="@id/homeRecruiterFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeSeekerFragment"
        android:name="com.proweb.jobskuy.ui.home.HomeSeekerFragment"
        android:label="Daftar Lowongan"
        tools:layout="@layout/fragment_home_seeker">
        <action
            android:id="@+id/action_homeSeeker_to_jobDetail"
            app:destination="@id/jobDetailFragment" />
        <action
            android:id="@+id/action_homeSeeker_to_profileAccount"
            app:destination="@id/profileAccountSeekerFragment" />
    </fragment>

    <fragment
        android:id="@+id/myApplicationsFragment"
        android:name="com.proweb.jobskuy.ui.home.MyApplicationsFragment"
        android:label="Lamaran Saya"
        tools:layout="@layout/fragment_my_applications" />

    <fragment
        android:id="@+id/profileSeekerFragment"
        android:name="com.proweb.jobskuy.ui.profile.ProfileSeekerFragment"
        android:label="Profil Publik Seeker"
        tools:layout="@layout/fragment_profile_seeker" />

    <fragment
        android:id="@+id/jobDetailFragment"
        android:name="com.proweb.jobskuy.ui.home.JobDetailFragment"
        android:label="Detail Pekerjaan"
        tools:layout="@layout/fragment_job_detail" />

    <fragment
        android:id="@+id/profileAccountSeekerFragment"
        android:name="com.proweb.jobskuy.ui.profile.ProfileAccountSeekerFragment"
        android:label="Profil Akun"
        tools:layout="@layout/fragment_profile_account_seeker">
        <action
            android:id="@+id/action_profileAccount_to_roleSelection"
            app:destination="@id/roleSelectionFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>